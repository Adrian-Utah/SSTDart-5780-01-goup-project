 168:Src/system_stm32f0xx.c **** /**
 169:Src/system_stm32f0xx.c ****    * @brief  Update SystemCoreClock variable according to Clock Register Values.
 170:Src/system_stm32f0xx.c ****   *         The SystemCoreClock variable contains the core clock (HCLK), it can
 171:Src/system_stm32f0xx.c ****   *         be used by the user application to setup the SysTick timer or configure
 172:Src/system_stm32f0xx.c ****   *         other parameters.
ARM GAS  /tmp/ccaHDSXR.s 			page 6


 173:Src/system_stm32f0xx.c ****   *
 174:Src/system_stm32f0xx.c ****   * @note   Each time the core clock (HCLK) changes, this function must be called
 175:Src/system_stm32f0xx.c ****   *         to update SystemCoreClock variable value. Otherwise, any configuration
 176:Src/system_stm32f0xx.c ****   *         based on this variable will be incorrect.
 177:Src/system_stm32f0xx.c ****   *
 178:Src/system_stm32f0xx.c ****   * @note   - The system frequency computed by this function is not the real
 179:Src/system_stm32f0xx.c ****   *           frequency in the chip. It is calculated based on the predefined
 180:Src/system_stm32f0xx.c ****   *           constant and the selected clock source:
 181:Src/system_stm32f0xx.c ****   *
 182:Src/system_stm32f0xx.c ****   *           - If SYSCLK source is HSI, SystemCoreClock will contain the HSI_VALUE(*)
 183:Src/system_stm32f0xx.c ****   *
 184:Src/system_stm32f0xx.c ****   *           - If SYSCLK source is HSE, SystemCoreClock will contain the HSE_VALUE(**)
 185:Src/system_stm32f0xx.c ****   *
 186:Src/system_stm32f0xx.c ****   *           - If SYSCLK source is PLL, SystemCoreClock will contain the HSE_VALUE(**)
 187:Src/system_stm32f0xx.c ****   *             or HSI_VALUE(*) multiplied/divided by the PLL factors.
 188:Src/system_stm32f0xx.c ****   *
 189:Src/system_stm32f0xx.c ****   *         (*) HSI_VALUE is a constant defined in stm32f0xx_hal.h file (default value
 190:Src/system_stm32f0xx.c ****   *             8 MHz) but the real value may vary depending on the variations
 191:Src/system_stm32f0xx.c ****   *             in voltage and temperature.
 192:Src/system_stm32f0xx.c ****   *
 193:Src/system_stm32f0xx.c ****   *         (**) HSE_VALUE is a constant defined in stm32f0xx_hal.h file (default value
 194:Src/system_stm32f0xx.c ****   *              8 MHz), user has to ensure that HSE_VALUE is same as the real
 195:Src/system_stm32f0xx.c ****   *              frequency of the crystal used. Otherwise, this function may
 196:Src/system_stm32f0xx.c ****   *              have wrong result.
 197:Src/system_stm32f0xx.c ****   *
 198:Src/system_stm32f0xx.c ****   *         - The result of this function could be not correct when using fractional
 199:Src/system_stm32f0xx.c ****   *           value for HSE crystal.
 200:Src/system_stm32f0xx.c ****   *
 201:Src/system_stm32f0xx.c ****   * @param  None
 202:Src/system_stm32f0xx.c ****   * @retval None
 203:Src/system_stm32f0xx.c ****   */
 204:Src/system_stm32f0xx.c **** void SystemCoreClockUpdate (void)
 205:Src/system_stm32f0xx.c **** {
 117              		.loc 1 205 1 is_stmt 1 view -0
 118              		.cfi_startproc
 119              		@ args = 0, pretend = 0, frame = 0
